//WAPTP the exponential value for a given base and power (x ^ n)
import java.util.Scanner;
class  Power
{
	public static void main(String[] args) 
	{
		Scanner sc=new Scanner(System.in);
		System.out.println("Enter the x nuber");
		int x=sc.nextInt();
		System.out.println("Enter the n nuber");
		int n=sc.nextInt();

		int result=1;

		for(int i=1;i<=n;i++)
		{
			result=result*x;
		}
		System.out.println("Power value:"+result);
	}
}
